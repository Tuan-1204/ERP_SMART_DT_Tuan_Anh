<Window x:Class="ERP_SMART_DT_Tuan_Anh.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập"
        Width="1100"
        Height="700"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#EEF4F8"
        KeyDown="LoginWindow_KeyDown">

    <Border BorderBrush="#8A8A8A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#F7F7F7" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="ERP SMART DT Tuấn Anh - Đăng nhập"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="14"
                           Foreground="#555"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="Minimize_Click"/>
                    <Button Content="□" Style="{StaticResource WindowControlButtonStyle}" Click="Maximize_Click"/>
                    <Button Content="X"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Background="{StaticResource DangerBrush}"
                            Foreground="White"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="24"
                    CornerRadius="14"
                    Background="#EFFFFFFF"
                    Padding="54">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Đăng nhập"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>

                        <TextBlock Text="Chào mừng bạn quay lại hệ thống"
                                   FontSize="18"
                                   Margin="0,12,0,34"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Text="Tên đăng nhập"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>

                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 Margin="0,8,0,24"/>

                        <TextBlock Text="Mật khẩu"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>

                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource AppPasswordBoxStyle}"
                                     Margin="0,8,0,18"/>

                        <Grid Margin="0,0,0,28">
                            <CheckBox Content="Ghi nhớ đăng nhập"
                                      FontSize="14"
                                      IsChecked="{Binding RememberMe}"/>
                            <TextBlock Text="Quên mật khẩu"
                                       HorizontalAlignment="Right"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>

                        <Button Content="Đăng nhập"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="54"
                                FontSize="18"
                                IsDefault="True"
                                Click="Login_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="ERP-Smart"
                                   FontSize="72"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Điện Tử Tuấn Anh"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Hệ thống ERP quản lý kho thông minh theo IMEI, hỗ trợ nhập kho, xuất kho, công nợ, kiểm kê, bảo hành, trả hàng và dự đoán tồn kho tối thiểu."
                                   Width="470"
                                   FontSize="18"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,28,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
