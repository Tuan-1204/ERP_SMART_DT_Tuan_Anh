<Window x:Class="ERP_SMART_DT_Tuan_Anh.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERP SMART DT Tuấn Anh"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <Border BorderBrush="#777" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="ERP-Smart"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Margin="28,26,0,0"/>

                        <TextBlock Text="Điện Tử Tuấn Anh"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="30,-6,0,26"/>
                    </StackPanel>

                    <StackPanel>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowDashboardCommand}" Content="▦  Tổng quan"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowProductCommand}" Content="▣  Sản phẩm"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowCategoryCommand}" Content="▤  Danh mục"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowImeiCommand}" Content="▥  IMEI"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowImportCommand}" Content="+  Nhập kho"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowExportCommand}" Content="↗  Xuất kho"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowCustomerCommand}" Content="☺  Khách hàng"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowSupplierCommand}" Content="▧  Nhà cung cấp"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowDebtCommand}" Content="$  Công nợ"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowForecastCommand}" Content="▲  Dự báo tồn kho"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,24">
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowSettingCommand}" Content="⚙  Cài đặt"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowAuditCommand}" Content="☷  Nhật ký"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="↩  Đăng xuất" Click="Logout_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="#F7F7F7"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="520"
                            Height="36"
                            Background="White"
                            BorderBrush="#888"
                            BorderThickness="1"
                            CornerRadius="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBox BorderThickness="0"
                                 FontSize="15"
                                 Margin="18,0"
                                 VerticalContentAlignment="Center"
                                 Text="Tìm kiếm"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="28"
                                   FontStyle="Italic"
                                   FontWeight="SemiBold"
                                   Foreground="#555"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"/>
                        <Button Content="Thông báo"
                                Command="{Binding ShowNotificationCommand}"
                                Style="{StaticResource OutlineButtonStyle}"
                                Height="34"
                                MinWidth="92"
                                Margin="0,0,10,0"/>
                        <Button Content="Tài khoản"
                                Command="{Binding ShowAccountCommand}"
                                Style="{StaticResource OutlineButtonStyle}"
                                Height="34"
                                MinWidth="86"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Content="─" Style="{StaticResource WindowControlButtonStyle}" Click="Minimize_Click"/>
                        <Button Content="□" Style="{StaticResource WindowControlButtonStyle}" Click="Maximize_Click"/>
                        <Button Content="X"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Background="{StaticResource DangerBrush}"
                                Foreground="White"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        BorderBrush="#999"
                        BorderThickness="0,1,0,1">
                    <DockPanel Margin="20,0">
                        <TextBlock Text="{Binding PageTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding Breadcrumb}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>

                <ContentControl Grid.Row="2"
                                Content="{Binding CurrentView}"
                                Margin="16"/>
            </Grid>
        </Grid>
    </Border>
</Window>
