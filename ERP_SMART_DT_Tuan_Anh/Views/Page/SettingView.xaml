<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}" Width="620" HorizontalAlignment="Left">
        <StackPanel>
            <TextBlock Text="Cấu hình hệ thống" FontSize="24" FontWeight="Bold" Margin="0,0,0,22"/>

            <TextBlock Text="Tên cửa hàng"/>
            <TextBox Text="{Binding Setting.ShopName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,14"/>

            <TextBlock Text="Địa chỉ"/>
            <TextBox Text="{Binding Setting.Address}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,14"/>

            <TextBlock Text="Số điện thoại"/>
            <TextBox Text="{Binding Setting.Phone}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,14"/>

            <TextBlock Text="Giao diện"/>
            <ComboBox SelectedValue="{Binding Setting.Theme}" Height="42" Margin="0,5,0,22">
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
            </ComboBox>

            <Button Content="Lưu cấu hình" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="48"/>
        </StackPanel>
    </Border>
</UserControl>