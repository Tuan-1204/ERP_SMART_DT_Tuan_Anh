<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ImportStockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1150">
    <Border Background="White" CornerRadius="8" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="390"/>
            </Grid.ColumnDefinitions>

            <!-- KHU VỰC THÔNG TIN PHIẾU NHẬP (BÊN TRÁI) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Phiếu nhập kho hàng thông minh"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,6"
                               Foreground="#1A202C"/>

                    <TextBlock Text="Quản lý nhập hàng thiết bị công nghệ định danh và hạch toán công nợ nhà cung cấp gối đầu"
                               FontSize="14"
                               Foreground="#718096"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"/>

                    <!-- BƯỚC 1: THÔNG TIN NCC -->
                    <Border Background="#F7FAFC" BorderBrush="#DCE6F0" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="1. Thông tin đối tác cung cấp" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#2B6CB0"/>
                            <TextBlock Text="Chọn nhà cung cấp đối tác" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4A5568"/>
                            <ComboBox ItemsSource="{Binding Suppliers}"
                                      SelectedItem="{Binding SelectedSupplier}"
                                      DisplayMemberPath="FullName"
                                      Height="40"
                                      VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- BƯỚC 2: CHỌN SẢN PHẨM & LỌC TÌM KIẾM THÔNG MINH -->
                    <Border Background="#F7FAFC" BorderBrush="#DCE6F0" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="2. Chọn mặt hàng công nghệ nhập kho" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#2B6CB0"/>

                            <TextBlock Text="Tìm kiếm nhanh sản phẩm (Gõ tên mã máy...)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4A5568"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="38" VerticalContentAlignment="Center" Padding="8,0,0,0"/>
                                <Button Grid.Column="1" Content="Lọc mã" Command="{Binding FilterProductCommand}" Margin="8,0,0,0" Background="#EDF2F7" FontWeight="SemiBold"/>
                            </Grid>

                            <TextBlock Text="Thiết bị công nghệ xác nhận chọn" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4A5568"/>
                            <ComboBox ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      DisplayMemberPath="ProductName"
                                      Height="40"
                                      VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- BƯỚC 3: GIÁ CẢ & THANH TOÁN (ĐÃ FIX TỰ ĐỘNG PHÂN CHIA TIỀN TỆ) -->
                    <Border Background="#F7FAFC" BorderBrush="#DCE6F0" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="3. Thông tin tài chính &amp; Thanh toán hạch toán" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#2B6CB0"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ô ĐƠN GIÁ NHẬP -->
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Đơn giá nhập kho (VND)" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568"/>
                                    <Grid Margin="0,6,0,0">
                                        <TextBox x:Name="TxtUnitPrice" 
                                                 Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                 Height="40" VerticalContentAlignment="Center" Padding="8,0,0,0" FontWeight="SemiBold"/>
                                        <!-- Watermark chữ 0 mờ -->
                                        <TextBlock Text="0" Foreground="#A0AEC0" FontSize="14" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=TxtUnitPrice, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>

                                <!-- Ô ĐÃ TRẢ TRƯỚC -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Đã trả trước cho NCC (VND)" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568"/>
                                    <Grid Margin="0,6,0,0">
                                        <TextBox x:Name="TxtPaidAmount" 
                                                 Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                 Height="40" VerticalContentAlignment="Center" Padding="8,0,0,0" FontWeight="SemiBold"/>
                                        <!-- Watermark chữ 0 mờ -->
                                        <TextBlock Text="0" Foreground="#A0AEC0" FontSize="14" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=TxtPaidAmount, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Ghi chú chứng từ phiếu nhập" FontSize="13" FontWeight="SemiBold" Margin="0,12,0,0" Foreground="#4A5568"/>
                            <TextBox Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="8" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- KHU VỰC NHẬP IMEI & TÓM TẮT PHIẾU HÀNG (BÊN PHẢI) -->
            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <Border Background="#F7FAFC" BorderBrush="#DCE6F0" BorderThickness="1" CornerRadius="8" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Khai báo danh sách IMEI mới" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Nhập hoặc quét mã từ vỏ hộp (Mỗi mã 1 dòng, >=10 số)." FontSize="13" Foreground="#718096" Margin="0,0,0,10"/>

                        <TextBox Text="{Binding ImeiText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="230" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14" Padding="8" Background="White"/>
                    </StackPanel>
                </Border>

                <!-- TÓM TẮT TIỀN TỰ ĐỘNG LÀM MỚI -->
                <Border Background="#FFF8E8" BorderBrush="#E3C370" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Tóm tắt phiếu nhập kho" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#8A6D3B"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tổng số lượng nhập máy:" FontSize="13" Foreground="#555555"/>
                            <TextBlock Grid.Column="1" Text="{Binding QuantityText}" FontSize="14" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tổng giá trị tiền hàng:" FontSize="13" Foreground="#555555"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmountText}" FontSize="14" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cửa hàng ghi nợ NCC lũy kế:" FontSize="13" Foreground="#555555"/>
                            <TextBlock Grid.Column="1" Text="{Binding RemainingSupplierDebtText}" FontSize="14" FontWeight="Bold" Foreground="#E53E3E"/>
                        </Grid>

                        <Separator Background="#E3C370" Margin="0,6,0,8"/>
                        <TextBlock Text="{Binding PaymentStatusText}" FontSize="13" FontStyle="Italic" TextWrapping="Wrap" Foreground="#718096"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Nhập lại" 
                            Command="{Binding ResetFormCommand}" 
                            Height="48" FontSize="14" FontWeight="SemiBold" Background="#EDF2F7" Foreground="#4A5568" BorderBrush="#CBD5E0"/>

                    <Button Grid.Column="1" 
                            Content="Xác nhận lưu phiếu nhập"
                            Command="{Binding ImportCommand}"
                            Background="#2B6CB0" Foreground="White" FontWeight="Bold" Height="48" FontSize="15" Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>