<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Nhật ký hệ thống" FontSize="24" FontWeight="Bold" Margin="0,0,0,14"/>

            <DataGrid ItemsSource="{Binding Logs}" Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Thời gian" Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="170"/>
                    <DataGridTextColumn Header="UserId" Binding="{Binding UserId}" Width="80"/>
                    <DataGridTextColumn Header="Hành động" Binding="{Binding Action}" Width="140"/>
                    <DataGridTextColumn Header="Bảng" Binding="{Binding TableName}" Width="130"/>
                    <DataGridTextColumn Header="RecordId" Binding="{Binding RecordId}" Width="120"/>
                    <DataGridTextColumn Header="Dữ liệu cũ" Binding="{Binding OldData}" Width="*"/>
                    <DataGridTextColumn Header="Dữ liệu mới" Binding="{Binding NewData}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</UserControl>