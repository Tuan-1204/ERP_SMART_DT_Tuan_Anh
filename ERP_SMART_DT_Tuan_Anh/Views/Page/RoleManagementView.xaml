<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.RoleManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding CurrentRole}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vai trò" Binding="{Binding RoleName}" Width="220"/>
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Vai trò người dùng" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>
                <TextBlock Text="Tên vai trò"/>
                <TextBox Text="{Binding CurrentRole.RoleName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>
                <TextBlock Text="Mô tả"/>
                <TextBox Text="{Binding CurrentRole.Description}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,18"/>
                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>