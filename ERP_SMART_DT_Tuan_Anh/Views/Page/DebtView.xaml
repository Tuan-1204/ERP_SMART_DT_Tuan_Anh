<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.DebtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Thanh toán công nợ" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                <TextBlock Text="Đối tác"/>
                <ComboBox ItemsSource="{Binding Partners}"
                          SelectedItem="{Binding SelectedPartner}"
                          DisplayMemberPath="FullName"
                          Height="42"
                          Margin="0,6,0,14"/>

                <TextBlock Text="Số tiền thanh toán"/>
                <TextBox Text="{Binding PaymentAmount}" Style="{StaticResource AppTextBoxStyle}" Margin="0,6,0,14"/>

                <TextBlock Text="Ghi chú"/>
                <TextBox Text="{Binding Note}" Height="90" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,18"/>

                <Button Content="Ghi nhận thanh toán"
                        Command="{Binding PayDebtCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="48"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Lịch sử công nợ" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

                <DataGrid ItemsSource="{Binding Transactions}" Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding TransactionDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Mã hóa đơn" Binding="{Binding BillId}" Width="140"/>
                        <DataGridTextColumn Header="Loại" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="Số tiền" Binding="{Binding Amount, StringFormat={}{0:N0}}" Width="130"/>
                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>