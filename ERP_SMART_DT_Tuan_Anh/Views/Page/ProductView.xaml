<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1100">
    <Grid Background="#F8FAFC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <!-- KHU VỰC DANH SÁCH & BỘ LỌC ĐA NĂNG (BÊN TRÁI) -->
        <Border Style="{StaticResource CardStyle}" Margin="16" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TIÊU ĐỀ & NÚT TẢI LẠI -->
                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Danh sách sản phẩm thiết bị"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               DockPanel.Dock="Left"/>
                    <Button Content="🔄 Tải lại"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="90" Height="36"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <!-- THANH BỘ LỌC ĐA TẦNG TIÊU CHUẨN ERP -->
                <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <!-- Giá tối thiểu -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Giá bán từ (VND)" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FilterMinPriceText, UpdateSourceTrigger=PropertyChanged, Delay=300}" 
                                     Height="36" VerticalContentAlignment="Center" Padding="8,0" Background="White"/>
                        </StackPanel>

                        <!-- Giá tối đa -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Đến giá bán (VND)" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FilterMaxPriceText, UpdateSourceTrigger=PropertyChanged, Delay=300}" 
                                     Height="36" VerticalContentAlignment="Center" Padding="8,0" Background="White"/>
                        </StackPanel>

                        <!-- Bộ sắp xếp tiêu chí nâng cao -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Sắp xếp theo tiêu chí" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                            <ComboBox SelectedIndex="{Binding SelectedSortIndex, UpdateSourceTrigger=PropertyChanged}" 
                                      Height="36" VerticalContentAlignment="Center" Background="White">
                                <ComboBoxItem Content="Mặc định (Theo mã máy)"/>
                                <ComboBoxItem Content="Giá bán: Thấp đến Cao 📈"/>
                                <ComboBoxItem Content="Giá bán: Cao đến Thấp 📉"/>
                                <ComboBoxItem Content="Ngày thêm: Mới nhất ⏱️"/>
                                <ComboBoxItem Content="Tên sản phẩm: A - Z 🔤"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Nút xóa bộ lọc -->
                        <Button Grid.Column="5" Content="Xóa bộ lọc" 
                                Command="{Binding ClearFilterCommand}"
                                Height="36" VerticalAlignment="Bottom" Margin="10,0,0,0"
                                Background="#E2E8F0" Foreground="#334155" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- LƯỚI HIỂN THỊ DỮ LIỆU SẢN PHẨM -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding FilteredProducts}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding ProductCode}" Width="110" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.CategoryName}" Width="130"/>
                        <DataGridTextColumn Header="Giá nhập" Binding="{Binding ImportPrice, StringFormat={}{0:N0} đ}" Width="120"/>
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding ExportPrice, StringFormat={}{0:N0} đ}" Width="120" FontWeight="SemiBold" Foreground="#2563EB"/>
                        <DataGridTextColumn Header="Tồn" Binding="{Binding CurrentStock}" Width="70"/>
                        <DataGridTextColumn Header="Tối thiểu" Binding="{Binding MinStock}" Width="90"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- KHU VỰC THAO TÁC THÔNG TIN FORM (BÊN PHẢI) -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,16,16,16" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Mã sản phẩm" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBox Text="{Binding CurrentProduct.ProductCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                    <TextBlock Text="Tên sản phẩm" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBox Text="{Binding CurrentProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                    <TextBlock Text="Danh mục" FontWeight="SemiBold" Foreground="#334155"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding CurrentProduct.CategoryId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="CategoryName"
                              Height="42" VerticalContentAlignment="Center" Margin="0,5,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Giá nhập (VND)" FontWeight="SemiBold" Foreground="#334155"/>
                            <TextBox Text="{Binding CurrentProduct.ImportPrice, Converter={StaticResource MoneyInputConverter}, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giá bán (VND)" FontWeight="SemiBold" Foreground="#334155"/>
                            <TextBox Text="{Binding CurrentProduct.ExportPrice, Converter={StaticResource MoneyInputConverter}, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tồn tối thiểu" FontWeight="SemiBold" Foreground="#334155"/>
                            <TextBox Text="{Binding CurrentProduct.MinStock, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ngưỡng cảnh báo" FontWeight="SemiBold" Foreground="#334155"/>
                            <TextBox Text="{Binding CurrentProduct.AlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Đơn vị tính" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBox Text="{Binding CurrentProduct.Unit, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,24"/>

                    <Button Content="+ Khởi tạo form mới"
                            Command="{Binding NewCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42" Margin="0,0,0,10" FontWeight="SemiBold"/>

                    <Button Content="💾 Lưu cập nhật sản phẩm"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="46" Margin="0,0,0,10" FontWeight="Bold" FontSize="14"/>

                    <Button Content="🗑️ Xóa sản phẩm khỏi hệ thống"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42" Foreground="#EF4444" BorderBrush="#FCA5A5"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>