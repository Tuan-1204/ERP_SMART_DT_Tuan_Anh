<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Danh sách sản phẩm"
                               FontSize="24"
                               FontWeight="Bold"
                               DockPanel.Dock="Left"/>
                    <Button Content="Tải lại"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding ProductCode}" Width="120"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.CategoryName}" Width="140"/>
                        <DataGridTextColumn Header="Giá nhập" Binding="{Binding ImportPrice, StringFormat={}{0:N0} VND}" Width="145"/>
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding ExportPrice, StringFormat={}{0:N0} VND}" Width="145"/>
                        <DataGridTextColumn Header="Tồn" Binding="{Binding CurrentStock}" Width="70"/>
                        <DataGridTextColumn Header="Tối thiểu" Binding="{Binding MinStock}" Width="90"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Mã sản phẩm"/>
                    <TextBox Text="{Binding CurrentProduct.ProductCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Tên sản phẩm"/>
                    <TextBox Text="{Binding CurrentProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Danh mục"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding CurrentProduct.CategoryId, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="CategoryName"
                              Height="42"
                              Margin="0,5,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Giá nhập (VND)"/>
                            <TextBox Text="{Binding CurrentProduct.ImportPrice, Converter={StaticResource MoneyInputConverter}, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Margin="0,5,0,12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giá bán (VND)"/>
                            <TextBox Text="{Binding CurrentProduct.ExportPrice, Converter={StaticResource MoneyInputConverter}, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Margin="0,5,0,12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tồn tối thiểu"/>
                            <TextBox Text="{Binding CurrentProduct.MinStock, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Margin="0,5,0,12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ngưỡng cảnh báo"/>
                            <TextBox Text="{Binding CurrentProduct.AlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Margin="0,5,0,12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Đơn vị tính"/>
                    <TextBox Text="{Binding CurrentProduct.Unit, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0,5,0,18"/>

                    <Border Background="#F7F7F7"
                            BorderBrush="#D6D6D6"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,18">
                     
                    </Border>

                    <Button Content="Tạo mới"
                            Command="{Binding NewCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42"
                            Margin="0,0,0,10"/>

                    <Button Content="Lưu sản phẩm"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="46"
                            Margin="0,0,0,10"/>

                    <Button Content="Xóa  sản phẩm"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
