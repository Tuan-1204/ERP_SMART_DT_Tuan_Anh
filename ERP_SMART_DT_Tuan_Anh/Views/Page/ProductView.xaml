<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="6">
                    <TextBlock Text="Mã sản phẩm" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CurrentProduct.ProductCode}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="6">
                    <TextBlock Text="Tên sản phẩm" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CurrentProduct.ProductName}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="6">
                    <TextBlock Text="Giá nhập" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CurrentProduct.ImportPrice}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="6">
                    <TextBlock Text="Giá bán" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CurrentProduct.ExportPrice}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <DataGrid ItemsSource="{Binding Products}"
                          SelectedItem="{Binding CurrentProduct}"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding ProductCode}" Width="120"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Giá nhập" Binding="{Binding ImportPrice, StringFormat={}{0:N0}}" Width="120"/>
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding ExportPrice, StringFormat={}{0:N0}}" Width="120"/>
                        <DataGridTextColumn Header="Tồn" Binding="{Binding CurrentStock}" Width="80"/>
                        <DataGridTextColumn Header="Tối thiểu" Binding="{Binding MinStock}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thao tác"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                    <Button Content="Lưu sản phẩm" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10"/>
                    <Button Content="Xóa mềm" Command="{Binding DeleteCommand}" Style="{StaticResource OutlineButtonStyle}"/>

                    <TextBlock Text="Lưu ý: tồn kho được SQL Trigger tự cập nhật theo IMEI trong kho."
                               TextWrapping="Wrap"
                               Margin="0,24,0,0"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>