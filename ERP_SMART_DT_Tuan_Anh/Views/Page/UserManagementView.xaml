<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding CurrentUser}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tài khoản" Binding="{Binding Username}" Width="140"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="180"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="130"/>
                    <DataGridTextColumn Header="Vai trò" Binding="{Binding Role.RoleName}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Người dùng" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                <TextBlock Text="Tên đăng nhập"/>
                <TextBox Text="{Binding CurrentUser.Username}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,10"/>

                <TextBlock Text="Mật khẩu mới"/>
                <TextBox Text="{Binding RawPassword}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,10"/>

                <TextBlock Text="Họ tên"/>
                <TextBox Text="{Binding CurrentUser.FullName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,10"/>

                <TextBlock Text="Email"/>
                <TextBox Text="{Binding CurrentUser.Email}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,10"/>

                <TextBlock Text="Số điện thoại"/>
                <TextBox Text="{Binding CurrentUser.Phone}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,10"/>

                <TextBlock Text="Vai trò"/>
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedValue="{Binding CurrentUser.RoleId}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="RoleName"
                          Height="42"
                          Margin="0,5,0,10"/>

                <CheckBox Content="Tài khoản hoạt động" IsChecked="{Binding CurrentUser.IsActive}" Margin="0,0,0,16"/>

                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Xóa " Command="{Binding DeleteCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>