<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding CurrentCustomer}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="140"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="190"/>
                    <DataGridTextColumn Header="Công nợ" Binding="{Binding TotalDebt, StringFormat={}{0:N0} VND}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Thông tin khách hàng"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,18"/>

                <TextBlock Text="Họ tên"/>
                <TextBox Text="{Binding CurrentCustomer.FullName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Số điện thoại"/>
                <TextBox Text="{Binding CurrentCustomer.Phone}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Email"/>
                <TextBox Text="{Binding CurrentCustomer.Email}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Địa chỉ"/>
                <TextBox Text="{Binding CurrentCustomer.Address}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,18"/>

                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Xóa " Command="{Binding DeleteCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
