<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding CurrentCategory}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên danh mục" Binding="{Binding CategoryName}" Width="220"/>
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Danh mục sản phẩm" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                <TextBlock Text="Tên danh mục"/>
                <TextBox Text="{Binding CurrentCategory.CategoryName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Mô tả"/>
                <TextBox Text="{Binding CurrentCategory.Description}" Height="110" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,18"/>

                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Xóa " Command="{Binding DeleteCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>