<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ImeiInventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource AppTextBoxStyle}"
                         FontSize="16"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Tìm IMEI"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,12,0"/>

                <Button Grid.Column="2"
                        Content="Tải lại"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource OutlineButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding ImeiList}"
                      SelectedItem="{Binding SelectedImei}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="IMEI" Binding="{Binding Imei}" Width="180"/>
                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding Product.ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Mã sản phẩm" Binding="{Binding Product.ProductCode}" Width="130"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status.StatusName}" Width="130"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Người tạo" Binding="{Binding CreatedBy}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>