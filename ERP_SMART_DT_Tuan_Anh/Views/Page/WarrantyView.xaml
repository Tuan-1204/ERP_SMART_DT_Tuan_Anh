<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.WarrantyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Warranties}"
                      SelectedItem="{Binding CurrentWarranty}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="IMEI" Binding="{Binding Imei}" Width="160"/>
                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ImeiInventory.Product.ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Ngày nhận" Binding="{Binding ReceiveDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Ngày trả" Binding="{Binding ReturnDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Chi phí" Binding="{Binding Cost, StringFormat={}{0:N0} VND}" Width="140"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Phiếu bảo hành" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                <TextBlock Text="IMEI"/>
                <TextBox Text="{Binding CurrentWarranty.Imei}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Mô tả lỗi"/>
                <TextBox Text="{Binding CurrentWarranty.Description}" Height="90" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,12"/>

                <TextBlock Text="Kết quả xử lý"/>
                <TextBox Text="{Binding CurrentWarranty.Result}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,12"/>

                <TextBlock Text="Chi phí"/>
                <TextBox Text="{Binding CurrentWarranty.Cost, Converter={StaticResource MoneyInputConverter}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Trạng thái"/>
                <TextBox Text="{Binding CurrentWarranty.Status}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,18"/>

                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu phiếu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
