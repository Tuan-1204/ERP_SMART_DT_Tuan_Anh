<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Suppliers}"
                      SelectedItem="{Binding CurrentSupplier}"
                      Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="140"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="190"/>
                    <DataGridTextColumn Header="Mã số thuế" Binding="{Binding TaxCode}" Width="130"/>
                    <DataGridTextColumn Header="Công nợ" Binding="{Binding TotalDebt, StringFormat={}{0:N0}}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Thông tin nhà cung cấp"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,18"/>

                <TextBlock Text="Tên nhà cung cấp"/>
                <TextBox Text="{Binding CurrentSupplier.FullName}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Số điện thoại"/>
                <TextBox Text="{Binding CurrentSupplier.Phone}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Email"/>
                <TextBox Text="{Binding CurrentSupplier.Email}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Mã số thuế"/>
                <TextBox Text="{Binding CurrentSupplier.TaxCode}" Style="{StaticResource AppTextBoxStyle}" Margin="0,5,0,12"/>

                <TextBlock Text="Địa chỉ"/>
                <TextBox Text="{Binding CurrentSupplier.Address}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,18"/>

                <Button Content="Tạo mới" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10"/>
                <Button Content="Xóa mềm" Command="{Binding DeleteCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>