<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ExportStockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1100">

    <Grid Background="#F8FAFC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- PHẦN THÔNG TIN PHIẾU XUẤT (BÊN TRÁI) -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <Border Background="White" CornerRadius="12" Margin="16" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                <StackPanel>
                    <TextBlock Text="Phiếu Xuất Kho Bán Hàng" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,4"/>
                    <TextBlock Text="Quét cấu hình thiết bị định danh và hạch toán tự động công nợ thu hồi khách hàng" FontSize="13" Foreground="#64748B" Margin="0,0,0,20"/>

                    <TextBlock Text="Khách hàng đối tác thu nhận" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                    <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="FullName" Height="40" FontSize="14" Margin="0,6,0,16" VerticalContentAlignment="Center"/>

                    <Grid>
                        <TextBlock Text="Sản phẩm dòng máy chọn xuất" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                        <TextBlock Text="{Binding ProductStockAvailableText}" FontSize="13" FontStyle="Italic" Foreground="#2563EB" HorizontalAlignment="Right" FontWeight="Medium"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="ProductName" Height="40" FontSize="14" Margin="0,6,0,16" VerticalContentAlignment="Center"/>

                    <!-- TRẠM QUÉT BARCODE IMEI -->
                    <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,4,0,16">
                        <StackPanel>
                            <TextBlock Text="Trạm quét Barcode / Mã IMEI máy thực tế" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                            <Grid Margin="0,6,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="8,0" Background="White" BorderBrush="#CBD5E1">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="Bắn mã" Command="{Binding ScanBarcodeCommand}" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Margin="8,0,0,0" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                            <TextBlock Text="{Binding ScanMessage}" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- KHỐI ĐƠN GIÁ & KHÁCH TRẢ -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ĐƠN GIÁ XUẤT BÁN -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Đơn giá xuất bán (VND)" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                            <Grid Margin="0,6,0,0">
                                <TextBox x:Name="TxtUnitPrice" Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged, Delay=300}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="8,0,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="0" Foreground="#A0AEC0" FontSize="14" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=TxtUnitPrice, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <!-- SỐ TIỀN KHÁCH TRẢ -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Số tiền khách trả mặt tiền (VND)" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                            <Grid Margin="0,6,0,0">
                                <TextBox x:Name="TxtPaidAmount" Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged, Delay=300}" Height="40" FontSize="14" VerticalContentAlignment="Center" Padding="8,0,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="0" Foreground="#A0AEC0" FontSize="14" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=TxtPaidAmount, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- PHẦN GIỎ HÀNG VÀ TÓM TẮT HÓA ĐƠN (BÊN PHẢI) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="12" Margin="0,16,16,8" Padding="16" BorderThickness="1" BorderBrush="#E2E8F0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Danh Sách IMEI Xuất Kho" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Đã quét: " FontSize="14" Foreground="#64748B"/>
                            <TextBlock Text="{Binding ScannedCount}" FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                            <TextBlock Text=" máy" FontSize="14" Foreground="#64748B"/>
                        </StackPanel>
                    </Grid>

                    <ListBox Grid.Row="1" ItemsSource="{Binding ImeiList}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,2,0,2">
                                    <Grid>
                                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                                        <Button Content="✕" Command="{Binding DataContext.RemoveImeiCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" HorizontalAlignment="Right" Foreground="#EF4444" Background="Transparent" BorderThickness="0" Padding="4,0" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- KHỐI TÓM TẮT TIỀN HẠCH TOÁN CHỨNG TỪ -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="0,8,16,16" Padding="16" BorderThickness="1" BorderBrush="#E2E8F0">
                <StackPanel>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tổng tiền hóa đơn xuất:" FontSize="14" Foreground="#475569"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" FontSize="18" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tiền thừa trả khách:" FontSize="14" Foreground="#475569"/>
                        <TextBlock Text="{Binding ChangeAmount, StringFormat={}{0:N0} đ}" FontSize="16" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,4,0,12">
                        <TextBlock Text="Khách ghi nợ cửa hàng:" FontSize="14" Foreground="#475569"/>
                        <TextBlock Text="{Binding RemainingAmount, StringFormat={}{0:N0} đ}" FontSize="16" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="LƯU PHIẾU XUẤT KHO" Command="{Binding ExportCommand}" Height="46" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Margin="0,4,0,0" Cursor="Hand"/>
                    <Button Content="Tải lại danh mục" Command="{Binding RefreshCommand}" Height="36" Background="Transparent" Foreground="#64748B" BorderBrush="#E2E8F0" Margin="0,8,0,0" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>