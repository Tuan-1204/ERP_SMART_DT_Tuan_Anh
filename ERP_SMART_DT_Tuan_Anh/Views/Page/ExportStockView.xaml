<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.ExportStockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Phiếu xuất kho / bán hàng"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Khách hàng" FontSize="15" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="FullName"
                          Height="42"
                          FontSize="15"
                          Margin="0,6,0,14"/>

                <TextBlock Text="Sản phẩm" FontSize="15" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="ProductName"
                          Height="42"
                          FontSize="15"
                          Margin="0,6,0,14"/>

                <TextBlock Text="Quét barcode/IMEI" FontSize="15" FontWeight="SemiBold"/>
                <Grid Margin="0,6,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Content="Xử lý"
                            Command="{Binding ScanBarcodeCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </Grid>

                <TextBlock Text="{Binding ScanMessage}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,14"/>

                <TextBlock Text="Đơn giá bán (VND)" FontSize="15" FontWeight="SemiBold"/>
                <TextBox Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource AppTextBoxStyle}"
                         Margin="0,6,0,14"/>

                <TextBlock Text="Số tiền khách đưa (VND)" FontSize="15" FontWeight="SemiBold"/>
                <TextBox Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource AppTextBoxStyle}"
                         Margin="0,6,0,14"/>

                <Border Background="#F7F7F7"
                        BorderBrush="#D6D6D6"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tổng tiền" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TotalAmount, StringFormat={}{0:N0} VND}"
                                   FontSize="16"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Text="Tiền thừa" FontSize="15" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding ChangeAmount, StringFormat={}{0:N0} VND}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="Còn nợ" FontSize="15" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding RemainingAmount, StringFormat={}{0:N0} VND}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}"
                                   Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <TextBlock Text="Ghi chú"
                           FontSize="15"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Hệ thống chỉ cho phép xuất các IMEI đang ở trạng thái Trong kho."
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="26,0,0,0">
                <TextBlock Text="Danh sách IMEI xuất kho"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <TextBox Text="{Binding ImeiText, UpdateSourceTrigger=PropertyChanged}"
                         Height="360"
                         FontSize="15"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <Button Content="Lưu phiếu xuất"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="50"
                        Margin="0,20,0,0"/>

                <Button Content="Tải lại dữ liệu"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource OutlineButtonStyle}"
                        Height="44"
                        Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
