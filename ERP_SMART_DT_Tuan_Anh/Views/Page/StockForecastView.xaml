<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.StockForecastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- THANH ĐIỀU CHỈNH THAM SỐ DỰ BÁO KHO -->
        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <!-- Ô 1: SỐ NGÀY PHÂN TÍCH -->
                    <StackPanel Width="150" Margin="0,0,16,0">
                        <TextBlock Text="Số ngày phân tích" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <TextBox x:Name="TxtAnalysis" Text="{Binding AnalysisDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" Height="36" VerticalContentAlignment="Center" Padding="6,0,0,0"/>
                            <TextBlock Text="0" Foreground="#A0AEC0" FontSize="13" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=TxtAnalysis, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- Ô 2: NGÀY CHỜ GIAO HÀNG -->
                    <StackPanel Width="150" Margin="0,0,16,0">
                        <TextBlock Text="Ngày chờ giao hàng" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <TextBox x:Name="TxtLeadTime" Text="{Binding LeadTimeDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" Height="36" VerticalContentAlignment="Center" Padding="6,0,0,0"/>
                            <TextBlock Text="0" Foreground="#A0AEC0" FontSize="13" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=TxtLeadTime, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- Ô 3: NGÀY AN TOÀN -->
                    <StackPanel Width="150" Margin="0,0,16,0">
                        <TextBlock Text="Ngày dự phòng an toàn" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <TextBox x:Name="TxtSafety" Text="{Binding SafetyDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" Height="36" VerticalContentAlignment="Center" Padding="6,0,0,0"/>
                            <TextBlock Text="0" Foreground="#A0AEC0" FontSize="13" IsHitTestVisible="False" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=TxtSafety, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- NÚT BẤM KÍCH HOẠT DỰ ĐOÁN -->
                    <Button Content="Chạy dự đoán"
                            Command="{Binding ForecastCommand}"
                            Background="#2B6CB0" Foreground="White" FontWeight="Bold"
                            Width="130" Height="36" VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- DÒNG TRẠNG THÁI HIỂN THỊ -->
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" 
                           VerticalAlignment="Bottom" FontStyle="Italic" Foreground="#718096" FontSize="13"/>
            </Grid>
        </Border>

        <!-- BẢNG HIỂN THỊ CHI TIẾT KẾT QUẢ KHO (DATA GRID) -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12">
            <DataGrid ItemsSource="{Binding Results}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      Background="White" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã sản phẩm" Binding="{Binding ProductCode}" Width="110" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Tên sản phẩm thiết bị" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Tồn hiện tại" Binding="{Binding CurrentStock}" Width="95"/>
                    <DataGridTextColumn Header="Đã bán ra" Binding="{Binding TotalSoldQuantity}" Width="95"/>

                    <!-- Làm tròn tốc độ bán trung bình ngày lấy 2 số sau dấu phẩy thập phân (Tối ưu UI/UX) -->
                    <DataGridTextColumn Header="Tốc độ bán (TB/Ngày)" Binding="{Binding AverageDailySales, StringFormat={}{0:F2}}" Width="145"/>

                    <DataGridTextColumn Header="Mức tồn tối thiểu" Binding="{Binding PredictedMinStock}" Width="150" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Gợi ý nên nhập thêm" Binding="{Binding SuggestedImportQuantity}" Width="160" Foreground="#E53E3E" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Ngày nhập dự kiến" 
                    Binding="{Binding ExpectedRestockDateText}" 
                    Width="180" 
                    FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStock}" Value="0">
                                        <Setter Property="Foreground" Value="#E53E3E"/>
                                        <!-- Màu Đỏ cho hàng hết -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Mức độ rủi ro kho" Binding="{Binding RiskLevelName}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>