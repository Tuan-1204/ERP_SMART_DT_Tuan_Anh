<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.StockForecastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="160" Margin="0,0,14,0">
                    <TextBlock Text="Số ngày phân tích"/>
                    <TextBox Text="{Binding AnalysisDays}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Width="160" Margin="0,0,14,0">
                    <TextBlock Text="Ngày nhập hàng"/>
                    <TextBox Text="{Binding LeadTimeDays}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Width="160" Margin="0,0,14,0">
                    <TextBlock Text="Ngày dự phòng"/>
                    <TextBox Text="{Binding SafetyDays}" Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <Button Content="Dự đoán"
                        Command="{Binding ForecastCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Results}" Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding ProductCode}" Width="100"/>
                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Tồn" Binding="{Binding CurrentStock}" Width="80"/>
                    <DataGridTextColumn Header="Đã bán" Binding="{Binding TotalSoldQuantity}" Width="80"/>
                    <DataGridTextColumn Header="TB/ngày" Binding="{Binding AverageDailySales}" Width="90"/>
                    <DataGridTextColumn Header="Tồn tối thiểu đề xuất" Binding="{Binding PredictedMinStock}" Width="150"/>
                    <DataGridTextColumn Header="Nên nhập" Binding="{Binding SuggestedImportQuantity}" Width="100"/>
                    <DataGridTextColumn Header="Còn ngày" Binding="{Binding DaysUntilOutOfStock}" Width="90"/>
                    <DataGridTextColumn Header="Rủi ro" Binding="{Binding RiskLevelName}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>