<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.InventoryCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Checks}" Style="{StaticResource AppDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã phiếu" Binding="{Binding Id}" Width="100"/>
                    <DataGridTextColumn Header="Ngày kiểm kê" Binding="{Binding CheckDate, StringFormat=dd/MM/yyyy HH:mm}" Width="170"/>
                    <DataGridTextColumn Header="Người tạo" Binding="{Binding User.FullName}" Width="160"/>
                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Tạo phiếu kiểm kê" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>
                <TextBlock Text="Ghi chú"/>
                <TextBox Text="{Binding Note}" Height="140" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,18"/>
                <Button Content="Tạo phiếu" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="48"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>