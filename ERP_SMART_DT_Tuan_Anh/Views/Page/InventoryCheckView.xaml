<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.InventoryCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1150">
    <Grid Background="#F8FAFC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- TẦNG 1: DANH SÁCH LỊCH SỬ PHIẾU KIỂM KÊ (BÊN TRÁI) -->
        <Border Style="{StaticResource CardStyle}" Margin="12,12,6,12" Padding="12" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="Nhật ký kiểm kê" FontSize="20" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    <Button Content="🔄 Tải lại" Command="{Binding LoadCommand}" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Right" Height="32" Padding="10,0" Cursor="Hand"/>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Checks}" SelectedItem="{Binding SelectedCheck}" AutoGenerateColumns="False" IsReadOnly="True" Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="70" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Ngày kiểm kho" Binding="{Binding CheckDate, StringFormat=dd/MM/yyyy HH:mm}" Width="*"/>
                        <DataGridTextColumn Header="Kế toán" Binding="{Binding User.FullName}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- TẦNG 2: CHI TIẾT DANH SÁCH MÁY KIỂM KÊ (KHU VỰC TRUNG TÂM UX) -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,12" Padding="14" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- ĐÃ FIX ĐỒNG BỘ: Sử dụng thẻ RowDefinitions số nhiều chuẩn xác tuyệt đối -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Chi tiết mặt hàng đối soát" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="💡 Mẹo: Nhấp đúp trực tiếp vào ô 'Tồn thực tế' trên lưới để nhập số liệu cân kho." FontSize="12" Foreground="#2563EB" FontWeight="Medium" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Background="#E0F2FE" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SystemModeText}" Foreground="#0369A1" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Details}" AutoGenerateColumns="False" IsReadOnly="{Binding IsReadOnlyGrid}" Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding ProductCode}" Width="100" IsReadOnly="True" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Tên dòng máy thiết bị" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>

                        <DataGridTextColumn Header="Tồn hệ thống" Binding="{Binding SystemStock}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tồn thực tế (Sửa ✍️)" Binding="{Binding ActualStock, UpdateSourceTrigger=PropertyChanged}" Width="125" EditingElementStyle="{StaticResource {x:Type TextBox}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Chênh lệch" Binding="{Binding Difference}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeficit}" Value="True">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSurplus}" Value="True">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- TẦNG 3: FORM ĐIỀU KHIỂN & CHỐT BIÊN BẢN (BÊN PHẢI - CHỐNG ĐÈ CHỮ) -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,12,12,12" Padding="16" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <Grid>
                <!-- Thêm RowDefinitions số nhiều để cô lập không gian hiển thị độc lập -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Visibility="{Binding FormVisibility, FallbackValue=Visible}">
                    <StackPanel>
                        <TextBlock Text="Biên bản quyết toán kho" FontSize="20" FontWeight="Bold" Foreground="#1A202C" Margin="0,0,0,16"/>

                        <TextBlock Text="Ghi chú / Lý do kiểm kê" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource AppTextBoxStyle}" Margin="0,6,0,20" Padding="8"/>

                        <Button Content="💾 LƯU PHIẾU KIỂM KÊ KHO" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Background="#10B981" Foreground="White" FontWeight="Bold" Height="48" FontSize="14" Margin="0,0,0,12" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="🔄 Huỷ bỏ / Làm mới form" Command="{Binding NewCommand}" Style="{StaticResource OutlineButtonStyle}" Height="40" Margin="0,0,0,12" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HistoryMessageVisibility, FallbackValue=Collapsed}">
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20,24" Width="330">
                        <StackPanel>
                            <TextBlock Text="🔒 CHẾ ĐỘ XEM LỊCH SỬ" FontSize="16" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center"/>
                            <TextBlock Text="Biên bản này đã được hạch toán và ký kết đóng sổ CSDL Cửa hàng. Hệ thống khóa quyền chỉnh sửa để bảo toàn tính minh bạch kế toán." 
                                       FontSize="13" Foreground="#64748B" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18"/>
                        </StackPanel>
                    </Border>
                    <Button Content="➕ Lập biên bản kiểm kho mới" Command="{Binding NewCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,24,0,0" Height="44" Width="240" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>