<UserControl x:Class="ERP_SMART_DT_Tuan_Anh.Views.Page.InventoryCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Phiếu kiểm kê"
                               FontSize="24"
                               FontWeight="Bold"
                               DockPanel.Dock="Left"/>
                    <Button Content="Tải lại"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Checks}"
                          SelectedItem="{Binding SelectedCheck}"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Ngày kiểm"
                                            Binding="{Binding CheckDate, StringFormat=dd/MM/yyyy HH:mm}"
                                            Width="150"/>
                        <DataGridTextColumn Header="Người tạo" Binding="{Binding User.FullName}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardStyle}"
                Margin="16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Chi tiết hàng cần kiểm"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Tồn hệ thống lấy từ sản phẩm, tồn thực tế là số lượng sau khi kiểm kê."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Details}"
                          SelectedItem="{Binding SelectedDetail}"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding ProductCode}" Width="130"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Tồn hệ thống" Binding="{Binding SystemStock}" Width="115"/>
                        <DataGridTextColumn Header="Tồn thực tế" Binding="{Binding ActualStock}" Width="115"/>
                        <DataGridTextColumn Header="Chênh lệch" Binding="{Binding Difference}" Width="105"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Ghi chú kiểm kê"/>
                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                             Height="92"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0,6,0,16"/>

                    <TextBlock Text="Chọn sản phẩm cần kiểm"/>
                    <ComboBox ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              DisplayMemberPath="ProductName"
                              Height="42"
                              Margin="0,6,0,12"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tồn hệ thống"/>
                            <Border Background="#F1F5F9"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,6,0,0">
                                <TextBlock Text="{Binding SelectedProduct.CurrentStock, TargetNullValue=0}"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tồn thực tế"/>
                            <TextBox Text="{Binding ActualStock, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Thêm vào phiếu"
                            Command="{Binding AddDetailCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="44"
                            Margin="0,0,0,10"/>

                    <Button Content="Xóa dòng đã chọn"
                            Command="{Binding RemoveDetailCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42"
                            Margin="0,0,0,22"/>

                    <Separator Margin="0,0,0,18"/>

                    <Button Content="{Binding SaveButtonText}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="48"
                            Margin="0,0,0,10"/>

                    <Button Content="Tạo mới"
                            Command="{Binding NewCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="42"
                            Margin="0,0,0,10"/>

                    <Button Content="Xóa phiếu"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource DangerBrush}"
                            Height="42"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
